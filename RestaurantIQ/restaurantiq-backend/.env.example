# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Square (use sandbox for local dev) ───────────────────────────────────────
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_LOCATION_ID=your-square-location-id

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Token encryption (AES-256-GCM for OAuth tokens stored at rest) ────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your-64-char-hex-string

# ── Distributed sync scheduler ────────────────────────────────────────────────
# Session pooler URL (port 5432, NOT 6543) — required for advisory lock leader
# election. Omit entirely for single-instance local dev (sole-leader fallback).
# DATABASE_URL=postgresql://postgres.your-project:password@pooler.supabase.com:5432/postgres
