# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override default model (claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...                  # service_role secret
SUPABASE_JWT_SECRET=...                           # Settings → API → JWT Settings → JWT Secret (HS256 only)

# --- Server ---
PORT=3001

# --- Square integration ---
# Where to point the SDK. Use 'sandbox' for dev, 'production' for live merchants.
SQUARE_ENVIRONMENT=sandbox

# Default access token used when a restaurant has no per-tenant token saved.
# Get one from https://developer.squareup.com/apps → your app → Sandbox → Access token.
SQUARE_ACCESS_TOKEN=EAAA...

# --- Feature flags ---
# When true, Square ingestion routes return immediately with mock=true and the
# dashboard keeps using whatever data is already in daily_summaries (e.g. seed.ts).
USE_MOCK=true
