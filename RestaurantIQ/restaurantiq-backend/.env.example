# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override default model (claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...                  # service_role secret
SUPABASE_JWT_SECRET=...                           # Settings → API → JWT Settings → JWT Secret (HS256 only)

# --- Server ---
PORT=3001
# Node environment. 'production' locks CORS to FRONTEND_URL only (no localhost),
# and hides internal error messages/stack traces from API responses.
NODE_ENV=development
# Version string reported by GET /health. Optional — defaults to the package.json
# version (npm sets npm_package_version via `npm start`), else 'unknown'.
# APP_VERSION=1.0.0

# --- Rate limiting (Claude-powered endpoints: /api/insights, /api/marketing) ---
# Per-user limits guard against abuse and runaway Anthropic API costs.
# Window length in minutes and max requests per user within that window.
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=50

# --- CORS ---
# Comma-separated list of allowed browser origins (the deployed frontend).
# Localhost dev origins are always allowed unless NODE_ENV=production.
# Local dev:   http://localhost:5173
# Production:  https://restaurantiq.vercel.app
# Multiple:    https://restaurantiq.vercel.app,https://www.restaurantiq.com
FRONTEND_URL=http://localhost:5173

# --- Square integration ---
# Where to point the SDK. Use 'sandbox' for dev, 'production' for live merchants.
SQUARE_ENVIRONMENT=sandbox

# Default access token used when a restaurant has no per-tenant token saved.
# Get one from https://developer.squareup.com/apps → your app → Sandbox → Access token.
SQUARE_ACCESS_TOKEN=EAAA...

# OAuth app credentials — required for automatic access-token refresh (Sprint K).
# Without these, an expired Square token marks the integration disconnected and
# the operator must reconnect manually.
SQUARE_APPLICATION_ID=sq0idp-...
SQUARE_APPLICATION_SECRET=sq0csp-...
# Optional overrides:
# SQUARE_OAUTH_BASE_URL=https://connect.squareupsandbox.com
# SQUARE_VERSION=2024-06-04

# --- Feature flags ---
# When true, Square ingestion routes return immediately with mock=true and the
# dashboard keeps using whatever data is already in daily_summaries (e.g. seed.ts).
USE_MOCK=true

# --- Distributed sync scheduler (Sprint L+) ---
# Direct Postgres connection string for the advisory-lock leader election client.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Get from Supabase: Settings → Database → Connection String → URI (use Transaction Pooler
# for app queries, but here we need the DIRECT connection for session-level advisory locks).
# If unset, the instance treats itself as the sole leader (single-instance / dev behaviour).
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Optional: give each backend instance a unique name for leader-election logs.
# Defaults to "<hostname>-<pid>".
# INSTANCE_ID=railway-instance-1

# Scheduler cadence (minutes between ticks). Default: 15.
SYNC_INTERVAL_MINUTES=15

# Max integrations dispatched per tick. Default: 50.
SYNC_BATCH_SIZE=50

# Max concurrent syncs per tick. Default: 5.
SYNC_MAX_CONCURRENCY=5

# Max retry attempts before a transient failure is marked failed_permanently.
# Backoff: 0s → 1m → 5m → 15m → 60m. Default: 5.
MAX_SYNC_RETRIES=5

# Set to false to disable the scheduler entirely (e.g. one-off scripts, CI).
SYNC_SCHEDULER_ENABLED=true

# --- Token encryption (AES-256-GCM) ---
# Encrypts integration tokens (Square/DoorDash) at rest. Each key is 64 hex
# chars = 32 bytes. Generate one with: openssl rand -hex 32
#
# ACTIVE_TOKEN_ENCRYPTION_KEY encrypts all new tokens. To rotate keys, move the
# previous key into the comma-separated LEGACY list — existing ciphertext stays
# readable and is transparently re-encrypted under the active key on next use.
# TOKEN_ENCRYPTION_KEY is still honored as a fallback when ACTIVE_* is unset.
ACTIVE_TOKEN_ENCRYPTION_KEY=your_64_hex_char_key
LEGACY_TOKEN_ENCRYPTION_KEYS=
TOKEN_ENCRYPTION_KEY=your_64_hex_char_key
